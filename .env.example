# ============================================================
# switchboard — environment. Copy to .env, fill in, NEVER commit.
# ============================================================

# ---- MaxoTel SIP trunk (my.maxo.com.au → SIP Trunks) ----
MAXO_USER=            # Register Username
MAXO_PASS=            # SIP password
AGENT_DID=            # the dedicated number MaxoTel routes to this trunk (E.164, e.g. 61731234567)

# ---- Caller allowlist ----
# Last 9 digits of YOUR mobile — only this CLID reaches the agent.
# (last-9 match normalises +61… / 0… / 61… formats). PII: stays out of git.
ALLOWED_CLID_9=

# ---- Grandstream HT802 (ATA) registers IN to Asterisk ----
HT802_PASS=           # local secret; also set this in the HT802 web UI

# ---- NAT / network (Asterisk advertises these in SDP) ----
LOCAL_NET=192.168.1.0/24      # your LAN subnet
EXTERNAL_IP=                  # public IP; blank = auto-detect

# ---- Claude ----
ANTHROPIC_API_KEY=
# Default is the most capable model. A real-time voice loop is latency-sensitive,
# so you may want to trade down: claude-haiku-4-5 (fastest) or claude-sonnet-4-6 (balanced).
CLAUDE_MODEL=claude-opus-4-8

# ---- Speech adapters (see agent/bridge.py) ----
STT_PROVIDER=echo     # echo | stub | whisper | deepgram
TTS_PROVIDER=echo     # echo | say | piper | google

# Piper TTS voice model path (defaults to agent/voices/en_GB-alan-low.onnx)
# PIPER_VOICE=

# Deepgram STT (STT_PROVIDER=deepgram) — telephony-tuned; sends raw 8kHz linear16.
# DEEPGRAM_API_KEY=
# DEEPGRAM_MODEL=nova-3              # try nova-2-phonecall on noisy lines
# DEEPGRAM_LANGUAGE=en
# DEEPGRAM_PROJECT_ID=               # pin which project's balance `switchboard status` reports

# Google Cloud TTS (TTS_PROVIDER=google) — REST + API key; returns LINEAR16 @ 8kHz.
# GOOGLE_CLOUD_API_KEY=
# GOOGLE_TTS_VOICE=en-AU-Neural2-B   # or a Chirp 3 HD voice, e.g. en-AU-Chirp3-HD-Charon

# ---- Coding agent (the "brain"; see agent/coding_agent.py + sessions.py) ----
# Default agent backend; `switchboard session start <context> <agent>` overrides per session.
AGENT_PROVIDER=claude   # claude (Claude Agent SDK) | opencode (OpenRouter)
# Context -> working dir is defined in sessions.py (CONTEXTS). Session/context store path:
# SWITCHBOARD_DB=                    # default: agent/state/switchboard.db
# AGENT_MAX_TURNS=40
# AGENT_TIMEOUT_S=900

# Claude backend auth — prefer the subscription via a long-lived OAuth token
# (`claude setup-token`). If set, the agent scrubs ANTHROPIC_API_KEY so it bills the
# subscription, not per-token API. Fall back to ANTHROPIC_API_KEY above for API billing.
# CLAUDE_CODE_OAUTH_TOKEN=

# opencode backend (AGENT_PROVIDER=opencode) — set the key, pick a model in opencode.json
# OPENROUTER_API_KEY=

# ---- Security ----
# DTMF passcode gate: callers must key this on the keypad before the agent will act.
# Caller ID is spoofable, so this is the real second factor. Empty = no gate. Digits only.
# SWITCHBOARD_PIN=

# ---- AudioSocket bridge ----
AUDIOSOCKET_PORT=9000
